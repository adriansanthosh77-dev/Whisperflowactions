OPENAI_API_KEY=sk-...
WHISPER_MODEL_PATH=models/ggml-base.bin
WHISPER_BIN=whisper-cli         # or full path to whisper.cpp binary
WHISPER_LANGUAGE=auto           # auto | en | hi | es | ar | zh | ja | fr | de | etc.
BROWSER_PROFILE_PATH=           # optional: path to Chrome user profile
RECORD_VIDEO_DIR=               # optional: data/videos to record Playwright browser videos
RECORD_TRACE_DIR=               # optional: data/traces to record Playwright traces with snapshots

# ── LLM Provider ──────────────────────────────────────────────────────────
# "openai" (default) → uses GPT-4o-mini via API (needs OPENAI_API_KEY)
# "ollama"           → uses local Ollama model (no API key needed)
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini        # only used when LLM_PROVIDER=openai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2-vision     # llama3.2-vision (recommended) | llama3 | mistral
