# ── LLM Provider ──────────────────────────────────────────────────────
# "ollama" (default, free, local) — no API key needed
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
FAST_PLANNER=true

# ── Brain Router: Per-task model routing ──────────────────────────────
CODING_PROVIDER=ollama
CODING_MODEL=llama3.2:1b
CREATIVE_PROVIDER=ollama
CREATIVE_MODEL=llama3.2:1b
ANALYSIS_PROVIDER=ollama
ANALYSIS_MODEL=llama3.2:1b
RESEARCH_PROVIDER=ollama
RESEARCH_MODEL=llama3.2:1b
IMAGE_PROVIDER=ollama
IMAGE_MODEL=llava

# ── Speech-to-Text ────────────────────────────────────────────────────
# Primary: Parakeet TDT 0.6B (best accuracy, ~30x RT)
# Fallback: Whisper base.en (always available)
STT_PROVIDER=parakeet
STT_MODEL_LONG=medium.en
STT_LONG_THRESHOLD=2.0
STT_LOW_CONF_THRESHOLD=0.6
STT_THREADS=2
WHISPER_LANGUAGE=en

# ── Text-to-Speech ────────────────────────────────────────────────────
# Kokoro-82M via sherpa-onnx (offline, high quality, ~50ms generation)
TTS_PROVIDER=kokoro
TTS_VOICE=en-GB-RyanNeural

# ── Microphone ────────────────────────────────────────────────────────
MICROPHONE_INDEX=

# ── Browser ───────────────────────────────────────────────────────────
USE_OBSCURA=false
OBSCURA_PORT=9222

# ── User ──────────────────────────────────────────────────────────────
USER_TITLE=sir

# ── Advanced ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
JARVIS_INTERACTIVE=false

# ── Text Mode (no hotkeys needed) ─────────────────────────────────────
# Set to "text" to start JARVIS in chat/terminal mode.
# Or run: python core/orchestrator.py --text
# JARVIS_INTERACTIVE=text

# ── First-Run Setup ───────────────────────────────────────────────────
JARVIS_SETUP_DONE=true

# ── Vision-Guided Desktop Actions ─────────────────────────────────────
# VISION_GUIDED_CLICKS=true
