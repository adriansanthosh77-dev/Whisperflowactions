# ── LLM Provider ──────────────────────────────────────────────────────
# "ollama" (default, free, local) — no API key needed
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
FAST_PLANNER=true

# ── Brain Router: Per-task model routing ──────────────────────────────
CODING_PROVIDER=ollama
CODING_MODEL=llama3.2:1b
CREATIVE_PROVIDER=ollama
CREATIVE_MODEL=llama3.2:1b
ANALYSIS_PROVIDER=ollama
ANALYSIS_MODEL=llama3.2:1b
RESEARCH_PROVIDER=ollama
RESEARCH_MODEL=llama3.2:1b
IMAGE_PROVIDER=ollama
IMAGE_MODEL=llava

# ── Speech-to-Text ────────────────────────────────────────────────────
# Short model (fast reflexes): tiny.en | small.en
# Long model (accurate dictation): medium.en | large-v3
STT_MODEL_SHORT=tiny.en
STT_MODEL_LONG=medium.en
STT_LONG_THRESHOLD=3.0
STT_LOW_CONF_THRESHOLD=0.6
STT_THREADS=2
WHISPER_LANGUAGE=en

# ── Text-to-Speech ────────────────────────────────────────────────────
TTS_PROVIDER=piper
TTS_VOICE_ID=

# ── Microphone ────────────────────────────────────────────────────────
# Run: python -m core.doctor, then set recommended input index
MICROPHONE_INDEX=
AUDIO_RING_BUFFER_MS=2000
MAX_RECORD_SECONDS=30

# ── Browser ───────────────────────────────────────────────────────────
# OPTION 1: Standard Browser (Chromium-based, visible)
# BROWSER_EXECUTABLE_PATH=C:\Program Files\BraveSoftware\Brave-Browser\Application\brave.exe
# OPTION 2: Obscura Stealth Engine (Windows only, headless)
USE_OBSCURA=false
OBSCURA_PORT=9222
OBSCURA_BIN=obscura.exe

# ── User ──────────────────────────────────────────────────────────────
USER_TITLE=sir

# ── Advanced ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
JARVIS_INTERACTIVE=false

# ── First-Run Setup (Auto-managed) ────────────────────────────────────
# JARVIS_SETUP_DONE=true  # Set automatically by the setup wizard

# ── Browser-Based Free LLM (Optional) ─────────────────────────────────
# Use free LLM websites via browser automation (no API key needed):
#   PROVIDER=browser  MODEL=chatgpt, claude, gemini, perplexity, huggingchat
# RESEARCH_PROVIDER=browser
# RESEARCH_MODEL=perplexity

# ── Vision-Guided Desktop Actions ─────────────────────────────────────
# When enabled, JARVIS uses the Moondream vision model to understand
# what's on your screen and guide desktop clicks/types.
# VISION_GUIDED_CLICKS=true

# ── DirectML GPU Acceleration (Windows only) ─────────────────────────
# Uses ONNX Runtime DirectML for GPU-accelerated vision model inference.
# Auto-detected; set to false to disable.
# USE_DIRECTML=true
