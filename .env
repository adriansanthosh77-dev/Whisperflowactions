OPENAI_API_KEY=sk-...
WHISPER_MODEL_PATH=models/ggml-base.en.bin
WHISPER_BIN=whisper-cli         # or full path to whisper.cpp binary
BROWSER_PROFILE_PATH=           # optional: path to Chrome user profile
RECORD_VIDEO_DIR=               # optional: data/videos to record Playwright browser videos
RECORD_TRACE_DIR=               # optional: data/traces to record Playwright traces with snapshots
